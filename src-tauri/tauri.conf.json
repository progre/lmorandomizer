{
  "productName": "lmorandomizer",
  "version": "0.10.0",
  "identifier": "net.prgrssv.lmorandomizer",
  "build": {
    "beforeDevCommand": "cargo build --package lmorandomizer-lib --target i686-pc-windows-msvc && copy target\\i686-pc-windows-msvc\\debug\\hook.dll target\\debug && npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "",
        "width": 800,
        "height": 535,
        "visible": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": ["res/*"]
  }
}
